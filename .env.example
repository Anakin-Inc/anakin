# AnakinScraper Configuration
# Copy to .env and modify as needed

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/anakinscraper?sslmode=disable

# Server
PORT=8080

# Browser Service (Playwright WebSocket)
BROWSER_WS_URL=ws://localhost:9222/camoufox
BROWSER_TIMEOUT=60
BROWSER_LOAD_WAIT=2

# Job Processing
WORKER_POOL_SIZE=5
JOB_BUFFER_SIZE=100
JOB_TIMEOUT=120

# Logging
LOG_LEVEL=INFO

# Proxy (optional)
PROXY_URL=

# Gemini API key (optional — enables generateJson for structured data extraction)
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anakin.io API handler (optional — fallback when local HTTP + browser handlers fail)
# Get a free key at https://anakin.io/dashboard
# When set, adds anakin.io as the last handler in the chain for hard-to-scrape sites
ANAKIN_API_KEY=

# Telemetry (anonymous usage data — see TELEMETRY.md for details)
# Set to "off" to disable: TELEMETRY=off
# TELEMETRY=on
# TELEMETRY_URL=  # defaults to https://telemetry.anakin.io/v1/collect

# Rate limiting (per-IP): requests per minute. Set to 0 to disable.
RATE_LIMIT=60
