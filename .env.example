# AnakinScraper Configuration
# Copy to .env and modify as needed

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/anakinscraper?sslmode=disable

# Server
PORT=8080

# Browser Service (Playwright WebSocket)
BROWSER_WS_URL=ws://localhost:9222/playwright
BROWSER_TIMEOUT=60
BROWSER_LOAD_WAIT=2

# Job Processing
WORKER_POOL_SIZE=5
JOB_BUFFER_SIZE=100
JOB_TIMEOUT=120

# Logging
LOG_LEVEL=INFO

# Proxy (optional)
PROXY_URL=
